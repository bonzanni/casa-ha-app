# Test Dockerfile that layers the mock supervisor on top of the add-on image.
# Allows local testing without HA Supervisor.
#
# Build: docker build -f test-local/Dockerfile.test -t casa-test .
# Run:   docker run --rm -p 8080:8080 casa-test

# Base: ghcr.io/home-assistant/amd64-base-debian:bookworm
# Migrated from alpine-python:3.12 in v0.8.5 — mirrors the main
# casa-agent/Dockerfile migration shipped in v0.8.1. fastembed>=0.4
# depends on onnxruntime, which ships manylinux wheels only (no
# musllinux), so the Alpine base can't install the test dependencies.
#
# Digest pinned 2026-04-21. Refresh deliberately:
#   docker buildx imagetools inspect \
#     ghcr.io/home-assistant/amd64-base-debian:bookworm \
#     --format '{{ json . }}' | jq -r '.manifest.digest'
# Rationale: floating tags let a silent base-image update change
# test behaviour with no record in this repo. See 5.3 spec §4.
ARG BUILD_FROM=ghcr.io/home-assistant/amd64-base-debian@sha256:8dca988e5ecd0e890792d3d0c73333977314b177265108e4b559f2d9d22e85aa
FROM ${BUILD_FROM}

# --- Mirrors casa-agent/Dockerfile (Debian bookworm) ---
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
         python3 python3-pip python3-venv \
         nodejs npm git nginx-light jq curl ca-certificates netcat-openbsd \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code \
    && npm cache clean --force

ARG TTYD_VERSION=1.7.7
ARG TARGETARCH=amd64
RUN case "${TARGETARCH}" in \
        amd64) TTYD_ARCH="x86_64" ;; \
        arm64) TTYD_ARCH="aarch64" ;; \
        *) echo "Unsupported arch: ${TARGETARCH}" && exit 1 ;; \
    esac \
    && curl -fsSL \
       "https://github.com/tsl0922/ttyd/releases/download/${TTYD_VERSION}/ttyd.${TTYD_ARCH}" \
       -o /usr/bin/ttyd \
    && chmod +x /usr/bin/ttyd

# Python venv at /opt/casa/venv (mirrors main Dockerfile) — Debian 12
# system Python is PEP 668 "externally managed"; the venv keeps pip off
# system site-packages without --break-system-packages.
RUN python3 -m venv /opt/casa/venv
ENV PATH="/opt/casa/venv/bin:${PATH}"

COPY casa-agent/requirements.txt /tmp/
RUN /opt/casa/venv/bin/pip install --no-cache-dir -r /tmp/requirements.txt

# E2E: swap the real Claude Agent SDK for the offline mock.
COPY test-local/mock-claude-sdk /tmp/mock-claude-sdk
RUN /opt/casa/venv/bin/pip install --no-cache-dir --force-reinstall --no-deps /tmp/mock-claude-sdk \
 && python3 -c "from claude_agent_sdk import ClaudeSDKClient; print('mock SDK active')"

COPY casa-agent/rootfs /

RUN find /etc/s6-overlay/s6-rc.d -name 'up' -o -name 'run' -o -name 'finish' \
    | xargs chmod +x \
    && chmod +x /opt/casa/scripts/*.sh

# --- Test layer: mock supervisor + options ---
# Use the tracked example file, not the gitignored options.json. Local devs
# who want real credentials mount options.json over /data/options.json at
# `docker run -v ...` time; CI builds get the placeholder-populated example.
COPY test-local/options.json.example /data/options.json

RUN mkdir -p /addon_configs/casa-agent /data/sdk-sessions \
             /etc/s6-overlay/scripts

# --- Override oneshot init scripts (no bashio in test mode) ---
# s6-rc oneshot 'up' files default to execline. We write shell scripts
# and point 'up' to them via: /bin/sh /path/to/script.sh

# init-validate-config
COPY test-local/init-overrides/validate-config-test.sh /etc/s6-overlay/scripts/
RUN printf '/bin/sh /etc/s6-overlay/scripts/validate-config-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-validate-config/up

# init-setup-configs
COPY test-local/init-overrides/01-setup-configs.sh /etc/s6-overlay/scripts/setup-configs-test.sh
RUN printf '/bin/sh /etc/s6-overlay/scripts/setup-configs-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-setup-configs/up

# init-setup-nginx
COPY test-local/init-overrides/02-setup-nginx.sh /etc/s6-overlay/scripts/setup-nginx-test.sh
RUN printf '/bin/sh /etc/s6-overlay/scripts/setup-nginx-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-setup-nginx/up

# init-export-env: exports options.json to s6 container env vars
RUN mkdir -p /etc/s6-overlay/s6-rc.d/init-export-env/dependencies.d \
    && printf 'oneshot\n' > /etc/s6-overlay/s6-rc.d/init-export-env/type \
    && touch /etc/s6-overlay/s6-rc.d/init-export-env/dependencies.d/init-setup-configs \
    && touch /etc/s6-overlay/s6-rc.d/user/contents.d/init-export-env
COPY test-local/init-overrides/03-export-env.sh /etc/s6-overlay/scripts/export-env-test.sh
RUN printf '/bin/sh /etc/s6-overlay/scripts/export-env-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-export-env/up

# svc-casa depends on init-export-env in test mode
RUN touch /etc/s6-overlay/s6-rc.d/svc-casa/dependencies.d/init-export-env

# --- Override longrun service scripts ---

# svc-casa: use with-contenv (reads s6 container env, no bashio)
RUN printf '#!/command/with-contenv sh\nexec python3 /opt/casa/casa_core.py\n' \
    > /etc/s6-overlay/s6-rc.d/svc-casa/run \
    && chmod +x /etc/s6-overlay/s6-rc.d/svc-casa/run

# svc-nginx: wait without bashio
RUN printf '#!/bin/sh\nfor i in $(seq 1 60); do\n  nc -z 127.0.0.1 8099 2>/dev/null && break\n  sleep 1\ndone\nexec nginx -g "daemon off;"\n' \
    > /etc/s6-overlay/s6-rc.d/svc-nginx/run \
    && chmod +x /etc/s6-overlay/s6-rc.d/svc-nginx/run

# svc-ttyd: read from options.json instead of bashio
RUN printf '#!/bin/sh\nENABLED=$(jq -r ".enable_terminal // false" /data/options.json)\nif [ "$ENABLED" != "true" ]; then\n  echo "[INFO] Web terminal disabled."\n  exec sleep infinity\nfi\nexec ttyd --writable --interface 127.0.0.1 --port 7681 --base-path /terminal --cwd /addon_configs/casa-agent bash\n' \
    > /etc/s6-overlay/s6-rc.d/svc-ttyd/run \
    && chmod +x /etc/s6-overlay/s6-rc.d/svc-ttyd/run

RUN chmod +x /etc/s6-overlay/scripts/*.sh

# --- Populate /opt/claude-seed/ (mirrors production Dockerfile §90..143) ---
# v0.14.9 seed-copy at boot expects this dir to exist with the install
# state for the 5 default plugins. Build it the same way production does
# so test container's setup-configs.sh seed-copy block has something to
# copy from. /etc/gitconfig (shipped via rootfs COPY above) handles the
# SSH→HTTPS rewrite for the github.com clones below.
COPY casa-agent/rootfs/opt/casa/defaults/marketplace-defaults/ /opt/casa/defaults/marketplace-defaults/

RUN id -u casa >/dev/null 2>&1 || useradd -m -s /bin/bash casa; \
    mkdir -p /opt/claude-seed && chown -R casa:casa /opt/claude-seed

USER casa

RUN CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin marketplace add /opt/casa/defaults/marketplace-defaults/ \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin install superpowers@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin enable  superpowers@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin install plugin-dev@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin enable  plugin-dev@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin install skill-creator@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin enable  skill-creator@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin install mcp-server-dev@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin enable  mcp-server-dev@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin install document-skills@casa-plugins-defaults \
 && CLAUDE_CODE_PLUGIN_CACHE_DIR=/opt/claude-seed \
    claude plugin enable  document-skills@casa-plugins-defaults

USER root

RUN mkdir -p /opt/claude-seed/marketplaces \
 && cp -r /opt/casa/defaults/marketplace-defaults \
          /opt/claude-seed/marketplaces/casa-plugins-defaults \
 && chmod -R a-w /opt/claude-seed \
 && chmod -R a+rX /opt/claude-seed

ENV CLAUDE_CODE_PLUGIN_SEED_DIR=/opt/claude-seed

ENV SUPERVISOR_TOKEN=mock-token-for-testing

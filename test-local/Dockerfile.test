# Test Dockerfile that layers the mock supervisor on top of the add-on image.
# Allows local testing without HA Supervisor.
#
# Build: docker build -f test-local/Dockerfile.test -t casa-test .
# Run:   docker run --rm -p 8080:8080 casa-test

ARG BUILD_FROM=ghcr.io/home-assistant/amd64-base-python:3.12-alpine3.22
FROM ${BUILD_FROM}

# --- Same as casa-agent/Dockerfile ---
RUN apk add --no-cache nodejs npm git nginx jq curl \
    && npm install -g @anthropic-ai/claude-code \
    && npm cache clean --force

ARG TTYD_VERSION=1.7.7
ARG TARGETARCH=amd64
RUN case "${TARGETARCH}" in \
        amd64) TTYD_ARCH="x86_64" ;; \
        arm64) TTYD_ARCH="aarch64" ;; \
        *) echo "Unsupported arch: ${TARGETARCH}" && exit 1 ;; \
    esac \
    && curl -fsSL \
       "https://github.com/tsl0922/ttyd/releases/download/${TTYD_VERSION}/ttyd.${TTYD_ARCH}" \
       -o /usr/bin/ttyd \
    && chmod +x /usr/bin/ttyd

COPY casa-agent/requirements.txt /tmp/
RUN pip3 install --no-cache-dir -r /tmp/requirements.txt

# E2E: swap the real Claude Agent SDK for the offline mock.
COPY test-local/mock-claude-sdk /tmp/mock-claude-sdk
RUN pip3 install --no-cache-dir --force-reinstall --no-deps /tmp/mock-claude-sdk \
 && python3 -c "from claude_agent_sdk import ClaudeSDKClient; print('mock SDK active')"

COPY casa-agent/rootfs /

RUN find /etc/s6-overlay/s6-rc.d -name 'up' -o -name 'run' -o -name 'finish' \
    | xargs chmod +x \
    && chmod +x /opt/casa/scripts/*.sh

# --- Test layer: mock supervisor + options ---
COPY test-local/options.json /data/options.json

RUN mkdir -p /addon_configs/casa-agent /data/sdk-sessions \
             /etc/s6-overlay/scripts

# --- Override oneshot init scripts (no bashio in test mode) ---
# s6-rc oneshot 'up' files default to execline. We write shell scripts
# and point 'up' to them via: /bin/sh /path/to/script.sh

# init-validate-config
COPY test-local/init-overrides/validate-config-test.sh /etc/s6-overlay/scripts/
RUN printf '/bin/sh /etc/s6-overlay/scripts/validate-config-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-validate-config/up

# init-setup-configs
COPY test-local/init-overrides/01-setup-configs.sh /etc/s6-overlay/scripts/setup-configs-test.sh
RUN printf '/bin/sh /etc/s6-overlay/scripts/setup-configs-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-setup-configs/up

# init-setup-nginx
COPY test-local/init-overrides/02-setup-nginx.sh /etc/s6-overlay/scripts/setup-nginx-test.sh
RUN printf '/bin/sh /etc/s6-overlay/scripts/setup-nginx-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-setup-nginx/up

# init-export-env: exports options.json to s6 container env vars
RUN mkdir -p /etc/s6-overlay/s6-rc.d/init-export-env/dependencies.d \
    && printf 'oneshot\n' > /etc/s6-overlay/s6-rc.d/init-export-env/type \
    && touch /etc/s6-overlay/s6-rc.d/init-export-env/dependencies.d/init-setup-configs \
    && touch /etc/s6-overlay/s6-rc.d/user/contents.d/init-export-env
COPY test-local/init-overrides/03-export-env.sh /etc/s6-overlay/scripts/export-env-test.sh
RUN printf '/bin/sh /etc/s6-overlay/scripts/export-env-test.sh\n' \
    > /etc/s6-overlay/s6-rc.d/init-export-env/up

# svc-casa depends on init-export-env in test mode
RUN touch /etc/s6-overlay/s6-rc.d/svc-casa/dependencies.d/init-export-env

# --- Override longrun service scripts ---

# svc-casa: use with-contenv (reads s6 container env, no bashio)
RUN printf '#!/command/with-contenv sh\nexec python3 /opt/casa/casa_core.py\n' \
    > /etc/s6-overlay/s6-rc.d/svc-casa/run \
    && chmod +x /etc/s6-overlay/s6-rc.d/svc-casa/run

# svc-nginx: wait without bashio
RUN printf '#!/bin/sh\nfor i in $(seq 1 60); do\n  nc -z 127.0.0.1 8099 2>/dev/null && break\n  sleep 1\ndone\nexec nginx -g "daemon off;"\n' \
    > /etc/s6-overlay/s6-rc.d/svc-nginx/run \
    && chmod +x /etc/s6-overlay/s6-rc.d/svc-nginx/run

# svc-ttyd: read from options.json instead of bashio
RUN printf '#!/bin/sh\nENABLED=$(jq -r ".enable_terminal // false" /data/options.json)\nif [ "$ENABLED" != "true" ]; then\n  echo "[INFO] Web terminal disabled."\n  exec sleep infinity\nfi\nexec ttyd --writable --interface 127.0.0.1 --port 7681 --base-path /terminal --cwd /addon_configs/casa-agent bash\n' \
    > /etc/s6-overlay/s6-rc.d/svc-ttyd/run \
    && chmod +x /etc/s6-overlay/s6-rc.d/svc-ttyd/run

RUN chmod +x /etc/s6-overlay/scripts/*.sh

ENV SUPERVISOR_TOKEN=mock-token-for-testing

# Template for test-local/smoke/.env.smoke (gitignored).
#
# Copy this file to .env.smoke in the same directory and fill in real
# values. The smoke scripts auto-source .env.smoke when present.
#
#   cp test-local/smoke/.env.smoke.example test-local/smoke/.env.smoke
#   $EDITOR test-local/smoke/.env.smoke
#
# Never commit the populated .env.smoke — it's in the repo .gitignore.

# The Casa bot's Telegram token (same one in the addon's telegram_bot_token).
# Get it from @BotFather. Format: "<digits>:<mixed>"
TELEGRAM_BOT_TOKEN=

# Chat ID of a DEDICATED TEST forum supergroup where smoke test topics
# can be created and deleted freely. Must be a negative integer
# starting with -100. Different from your production
# telegram_engagement_supergroup_id.
# Find it via https://api.telegram.org/bot<TOKEN>/getUpdates after
# posting in the group, or use @getidsbot.
TELEGRAM_TEST_SUPERGROUP_ID=

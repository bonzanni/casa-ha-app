{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "casa:policy-scopes.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scopes"],
  "properties": {
    "schema_version": {"const": 1},
    "scopes": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_-]*$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum_trust", "description"],
          "properties": {
            "minimum_trust": {
              "enum": ["internal", "authenticated", "external-authenticated",
                       "household-shared", "public"]
            },
            "description": {"type": "string", "minLength": 20}
          }
        }
      },
      "additionalProperties": false
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "casa:speaker-provenance.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["speaker_kind", "role_id", "persona_id", "persona_version", "display_name", "binding_digest", "user_peer", "user_id"],
  "properties": {
    "speaker_kind": {"enum": ["user", "resident", "specialist", "executor", "system"]},
    "role_id": {"type": ["string", "null"], "maxLength": 128, "pattern": "^(resident|specialist|executor):[a-z0-9][a-z0-9-]*$"},
    "persona_id": {"type": ["string", "null"], "maxLength": 192, "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?/[a-z0-9][a-z0-9-]*$"},
    "persona_version": {"type": ["string", "null"], "maxLength": 64, "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "display_name": {"type": ["string", "null"], "minLength": 1, "maxLength": 80},
    "binding_digest": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
    "user_peer": {"type": ["string", "null"], "minLength": 1, "maxLength": 256},
    "user_id": {"type": ["string", "null"], "minLength": 1, "maxLength": 256}
  },
  "allOf": [
    {"if": {"properties": {"speaker_kind": {"enum": ["resident", "specialist"]}}}, "then": {"required": ["role_id", "persona_id", "persona_version", "binding_digest"], "properties": {"role_id": {"type": "string"}, "persona_id": {"type": "string"}, "persona_version": {"type": "string"}, "binding_digest": {"type": "string"}, "user_peer": {"type": "null"}, "user_id": {"type": "null"}}}},
    {"if": {"properties": {"speaker_kind": {"const": "executor"}}}, "then": {"properties": {"role_id": {"type": "string", "pattern": "^executor:"}, "persona_id": {"type": "null"}, "persona_version": {"type": "null"}, "binding_digest": {"type": "null"}, "user_peer": {"type": "null"}, "user_id": {"type": "null"}}}},
    {"if": {"properties": {"speaker_kind": {"const": "user"}}}, "then": {"properties": {"role_id": {"type": "null"}, "persona_id": {"type": "null"}, "persona_version": {"type": "null"}, "binding_digest": {"type": "null"}, "user_peer": {"type": "string"}}}},
    {"if": {"properties": {"speaker_kind": {"const": "system"}}}, "then": {"properties": {"role_id": {"type": "null"}, "persona_id": {"type": "null"}, "persona_version": {"type": "null"}, "binding_digest": {"type": "null"}, "user_peer": {"type": "null"}, "user_id": {"type": "null"}}}}
  ]
}

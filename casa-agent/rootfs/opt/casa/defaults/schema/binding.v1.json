{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"casa:binding.v1","type":"object","additionalProperties":false,"required":["api_version","stable_agent_id","role_checksum","mode","persona_id","persona_version","persona_checksum","compiler_schema_version","dependency_digests","effective_config_digest","binding_digest"],"properties":{"api_version":{"const":"casa.binding/v1"},"stable_agent_id":{"type":"string","pattern":"^(resident|specialist):[a-z0-9][a-z0-9-]*$"},"role_checksum":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"mode":{"enum":["image-default","component-default","override"]},"persona_id":{"type":"string","pattern":"^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?/[a-z0-9][a-z0-9-]*$"},"persona_version":{"type":"string","pattern":"^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},"persona_checksum":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"compiler_schema_version":{"type":"string","minLength":1},"dependency_digests":{"type":"array","items":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"}},"effective_config_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"binding_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"image_default_root":{"type":["string","null"]},"component_root":{"type":["string","null"]},"override_source":{"type":["string","null"]}},"allOf":[{"if":{"properties":{"mode":{"const":"image-default"}}},"then":{"required":["image_default_root"]}},{"if":{"properties":{"mode":{"const":"component-default"}}},"then":{"required":["component_root"]}},{"if":{"properties":{"mode":{"const":"override"}}},"then":{"required":["override_source"]}}]}

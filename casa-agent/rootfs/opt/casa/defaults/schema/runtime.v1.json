{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "casa:runtime.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "model"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"enum": ["resident", "specialist", "executor"]},
    "model": {"oneOf": [
      {"type": "object", "additionalProperties": false, "required": ["source", "value"], "properties": {"source": {"const": "fixed"}, "value": {"enum": ["opus", "sonnet", "haiku"]}}},
      {"type": "object", "additionalProperties": false, "required": ["source", "option", "default", "allowed"], "properties": {"source": {"const": "ha_option"}, "option": {"enum": ["primary_agent_model", "voice_agent_model"]}, "default": {"enum": ["opus", "sonnet", "haiku"]}, "allowed": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["opus", "sonnet", "haiku"]}}}}
    ]},
    "enabled": {"type": "boolean", "default": true},
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed":         {"type": "array", "items": {"type": "string"}, "default": []},
        "disallowed":      {"type": "array", "items": {"type": "string"}, "default": []},
        "permission_mode": {"type": "string", "default": "acceptEdits"},
        "max_turns":       {"type": "integer", "minimum": 1, "default": 10},
        "skills":          {"type": "string", "enum": ["all", "none"], "default": "all"},
        "voice_guard":     {"type": "string", "enum": ["none", "ha_direct"], "default": "none"}
      }
    },
    "mcp_server_names": {"type": "array", "items": {"type": "string"}, "default": []},
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "token_budget":            {"type": "integer", "minimum": 0, "default": 4000},
        "read_strategy":           {"type": "string", "enum": ["per_turn", "cached"], "default": "per_turn"},
        "cross_peer_token_budget": {"type": "integer", "minimum": 0, "default": 2000}
      }
    },
    "channels": {"type": "array", "items": {"type": "string"}, "default": []},
    "session": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy":     {"type": "string", "enum": ["persistent", "pooled", "ephemeral"], "default": "ephemeral"},
        "idle_timeout": {"type": "integer", "minimum": 0, "default": 300}
      }
    },
    "tts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tag_dialect": {"type": "string", "enum": ["square_brackets", "parens", "none"], "default": "square_brackets"}
      }
    },
    "voice_errors": {"type": "object", "additionalProperties": {"type": "string"}, "default": {}},
    "cwd":          {"type": "string", "default": ""},
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plugins": {"type": "array", "items": {"type": "string"}, "default": []},
        "tools":   {"type": "array", "items": {"type": "string"}, "default": []}
      }
    }
  }
}

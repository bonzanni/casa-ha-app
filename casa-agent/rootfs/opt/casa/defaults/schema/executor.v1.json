{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "casa:executor.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "type", "description", "model", "driver"],
  "properties": {
    "schema_version": {"const": 1},
    "type": {"type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9_-]*$"},
    "description": {"type": "string", "minLength": 20},
    "model": {"type": "string", "minLength": 1},
    "driver": {"enum": ["in_casa", "claude_code"]},
    "enabled": {"type": "boolean", "default": true},
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": {"type": "array", "items": {"type": "string"}, "default": []},
        "disallowed": {"type": "array", "items": {"type": "string"}, "default": []},
        "permission_mode": {"enum": ["default", "acceptEdits", "bypassPermissions", "plan"], "default": "acceptEdits"}
      }
    },
    "mcp_server_names": {"type": "array", "items": {"type": "string"}, "default": []},
    "idle_reminder_days": {"type": "integer", "minimum": 1, "maximum": 365, "default": 7},
    "prompt_template_file": {"type": "string", "default": "prompt.md"},
    "hooks_file": {"type": "string", "default": "hooks.yaml"},
    "observer_policy_file": {"type": "string", "default": "observer.yaml"},
    "doctrine_dir": {"type": "string", "default": "doctrine"},
    "extra_dirs": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "mirror_chat_to_topic": {"type": "boolean", "default": true}
  }
}
